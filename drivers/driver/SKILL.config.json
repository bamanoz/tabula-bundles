{
  "id": "driver",
  "config": {
    "entries": [
      {
        "key": "openai_api_key",
        "type": "string",
        "secret": true,
        "required": false,
        "global_key": "openai.api_key",
        "env": "TABULA_SKILL_DRIVER_OPENAI_API_KEY",
        "env_aliases": ["OPENAI_API_KEY"],
        "store_ids": ["driver.openai.api_key", "driver-openai.api_key"]
      },
      {
        "key": "openai_base_url",
        "type": "string",
        "default": "https://api.openai.com/v1",
        "global_key": "openai.base_url",
        "env": "TABULA_SKILL_DRIVER_OPENAI_BASE_URL",
        "env_aliases": ["OPENAI_BASE_URL"]
      },
      {
        "key": "openai_model",
        "type": "string",
        "default": "gpt-5.4",
        "global_key": "openai.model",
        "env": "TABULA_SKILL_DRIVER_OPENAI_MODEL",
        "env_aliases": ["OPENAI_MODEL"]
      },
      {
        "key": "anthropic_api_key",
        "type": "string",
        "secret": true,
        "required": false,
        "global_key": "anthropic.api_key",
        "env": "TABULA_SKILL_DRIVER_ANTHROPIC_API_KEY",
        "env_aliases": ["ANTHROPIC_API_KEY"],
        "store_ids": ["driver.anthropic.api_key", "driver-anthropic.api_key"]
      },
      {
        "key": "anthropic_base_url",
        "type": "string",
        "default": "https://api.anthropic.com",
        "global_key": "anthropic.base_url",
        "env": "TABULA_SKILL_DRIVER_ANTHROPIC_BASE_URL",
        "env_aliases": ["ANTHROPIC_BASE_URL"]
      },
      {
        "key": "anthropic_model",
        "type": "string",
        "default": "claude-sonnet-4-6",
        "global_key": "anthropic.model",
        "env": "TABULA_SKILL_DRIVER_ANTHROPIC_MODEL",
        "env_aliases": ["ANTHROPIC_MODEL"]
      }
    ]
  }
}
